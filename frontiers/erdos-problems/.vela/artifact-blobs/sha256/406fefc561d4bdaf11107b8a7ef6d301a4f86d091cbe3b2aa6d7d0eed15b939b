/-! # Erd┼Љs Problem 150: Minimal Vertex Cuts

We formalise Brada─Ї's solution to Erd┼Љs Problem 150. The key result is that for any simple graph
`G` on a finite vertex set `V` and any two vertices `u РЅа v`, the number of inclusion-wise minimal
vertex sets separating `u` from `v` is at most `2 ┬и РѕЉ_{k=0}^{Рїі|V|/3РїІ} C(|V|, k)`.

This implies the growth rate `╬▒ = lim c(n)^{1/n}` satisfies `╬▒ < 2`, answering Erd┼Љs and
Ne┼Аet┼Ўil's question in the affirmative.
-/
namespace Erdos150

open Finset Fintype Real SimpleGraph

variable {V : Type*} [Fintype V] [DecidableEq V]

/-! ## Definitions -/

/-- `IsSeparator G u v T` holds when `T Ріє V \ {u,v}` separates `u` from `v`: every walk from `u`
to `v` in `G` passes through some vertex of `T`. -/
def IsSeparator (G : SimpleGraph V) (u v : V) (T : Finset V) : Prop :=
  u РѕЅ T РѕД v РѕЅ T РѕД Рѕђ w : G.Walk u v, РѕЃ x Рѕѕ w.support, x Рѕѕ T

/-- `IsMinSeparator G u v T` holds when `T` is an inclusion-wise minimal vertex separator of `u`
and `v` in `G`. -/
def IsMinSeparator (G : SimpleGraph V) (u v : V) (T : Finset V) : Prop :=
  IsSeparator G u v T РѕД Рѕђ T' : Finset V, T' Ріѓ T Рєњ ┬гIsSeparator G u v T'

/-- The set of all minimal `(u,v)`-separators in `G`. -/
def minSepSet (G : SimpleGraph V) (u v : V) : Set (Finset V) :=
  {T | IsMinSeparator G u v T}

/-- The number of minimal `(u,v)`-separators in `G`. -/
noncomputable def numMinSeps (G : SimpleGraph V) (u v : V) : РёЋ :=
  (minSepSet G u v).ncard

/-- The connected component of `u` in `G` avoiding `T`: the set of vertices reachable from `u` via
walks whose vertices all lie outside `T`. -/
def componentAvoiding (G : SimpleGraph V) (T : Finset V) (u : V) : Set V :=
  {x : V | РѕЃ w : G.Walk u x, Рѕђ y Рѕѕ w.support, y РѕЅ T}

/-- The outer neighbourhood of a set `S` in `G`: vertices outside `S` adjacent to some vertex in
`S`. -/
def outerNeighborhood (G : SimpleGraph V) [DecidableRel G.Adj] (S : Finset V) : Finset V :=
  univ.filter fun v Рєд v РѕЅ S РѕД РѕЃ u Рѕѕ S, G.Adj u v

/-! ## Helper lemmas -/

omit [Fintype V] [DecidableEq V] in
/-- A vertex belongs to its own component (when not in `T`). -/
lemma mem_componentAvoiding_self (G : SimpleGraph V) (T : Finset V) (u : V) (hu : u РѕЅ T) :
    u Рѕѕ componentAvoiding G T u :=
  РЪе.nil, fun y hy Рєд by
    simp only [Walk.support_nil, List.mem_cons, List.not_mem_nil, or_false] at hy; rwa [hy]РЪЕ

omit [Fintype V] [DecidableEq V] in
/-- The component avoiding `T` is disjoint from `T`. -/
lemma componentAvoiding_disjoint_T (G : SimpleGraph V) (T : Finset V) (u : V) :
    Disjoint (componentAvoiding G T u) (РєЉT : Set V) := by
  rw [Set.disjoint_left]
  intro x hx
  obtain РЪеw, hwРЪЕ := hx
  induction w <;> aesop

omit [Fintype V] [DecidableEq V] in
/-- The component is closed under adjacency outside `T`. -/
lemma componentAvoiding_adj_closed (G : SimpleGraph V) (T : Finset V) (u x y : V)
    (hx : x Рѕѕ componentAvoiding G T u) (hy : y РѕЅ T) (hadj : G.Adj x y) :
    y Рѕѕ componentAvoiding G T u := by
  obtain РЪеw, hwРЪЕ := hx
  exact РЪеw.append (.cons hadj .nil), by simp; aesopРЪЕ

omit [Fintype V] [DecidableEq V] in
/-- When `T` separates `u` from `v`, their components are disjoint. -/
lemma componentAvoiding_disjoint_uv (G : SimpleGraph V) (T : Finset V) (u v : V)
    (hsep : IsSeparator G u v T) :
    Disjoint (componentAvoiding G T u) (componentAvoiding G T v) := by
  rw [Set.disjoint_left]
  intro x hxРѓЂ hxРѓѓ
  obtain РЪеwРѓЂ, hwРѓЂРЪЕ := hxРѓЂ; obtain РЪеwРѓѓ, hwРѓѓРЪЕ := hxРѓѓ
  have РЪеw, hwРЪЕ : РѕЃ w : G.Walk u v, Рѕђ y Рѕѕ w.support, y РѕЅ T :=
    РЪеwРѓЂ.append wРѓѓ.reverse, fun y hy Рєд by
      simp only [Walk.mem_support_append_iff, Walk.support_reverse] at hy; aesopРЪЕ
  grind [hsep.2.2 w]

omit [Fintype V] [DecidableEq V] in
/-- Vertices adjacent to the component but outside it must lie in `T`. -/
lemma outerNbhd_component_sub (G : SimpleGraph V) (T : Finset V) (u : V) (x : V)
    (hx_not_comp : x РѕЅ componentAvoiding G T u)
    (hx_adj : РѕЃ y Рѕѕ componentAvoiding G T u, G.Adj y x) :
    x Рѕѕ (T : Set V) := by
  obtain РЪеy, hyРѓЂ, hyРѓѓРЪЕ := hx_adj
  exact not_not.1 fun hxРѓЃ Рєд hx_not_comp <|
    componentAvoiding_adj_closed G T u y x hyРѓЂ hxРѓЃ hyРѓѓ

omit [Fintype V] [DecidableEq V] in
/-- For a minimal separator, every vertex of `T` has a neighbour in the `u`-component.
Uses minimality: removing any vertex from `T` would reconnect `u` and `v`. -/
lemma minSep_T_sub_outerNbhd (G : SimpleGraph V) (T : Finset V) (u v : V)
    (hmin : IsMinSeparator G u v T) (x : V) (hxT : x Рѕѕ T) :
    РѕЃ y Рѕѕ componentAvoiding G T u, G.Adj y x := by
  classical
  by_contra h
  set T' := T.erase x
  have hT'_sep : IsSeparator G u v T' := by
    refine РЪе?_, ?_, ?_РЪЕ
    ┬и simp_all; have := hmin.1.1; aesop
    ┬и exact fun hv Рєд hmin.1.2.1 (mem_of_mem_erase hv)
    ┬и intro w
      by_contra h_contra
      push_neg at h_contra
      have hw_support : Рѕђ y Рѕѕ w.support, y РЅа x Рєњ y РѕЅ T := by
        grind
      have hw_support_x : x Рѕѕ w.support := by
        have := hmin.1.2.2 w; simp_all
        grind +ring
      obtain РЪеi, hiРЪЕ : РѕЃ i, w.getVert i = x РѕД Рѕђ j < i, w.getVert j РЅа x := by
        obtain РЪеi, hiРЪЕ : РѕЃ i, w.getVert i = x := by
          rw [Walk.mem_support_iff_exists_getVert] at hw_support_x; tauto
        use Nat.find (РЪеi, hiРЪЕ : РѕЃ i, w.getVert i = x)
        exact РЪеNat.find_spec (РЪеi, hiРЪЕ : РѕЃ i, w.getVert i = x),
          fun j hj hj' Рєд Nat.find_min (РЪеi, hiРЪЕ : РѕЃ i, w.getVert i = x) hj hj'РЪЕ
      have h_ind : Рѕђ j РЅц i, w.getVert j Рѕѕ componentAvoiding G T u := by
        intro j hj
        induction j with
        | zero =>
          simp_all only [not_exists, not_and, ne_eq, zero_le, Walk.getVert_zero]
          exact mem_componentAvoiding_self G T u (by have := hmin.1.1; aesop)
        | succ j ih => grind +suggestions
      have h_adj : G.Adj (w.getVert (i - 1)) x := by
        rcases i
        ┬и simp_all only [not_exists, not_and, nonpos_iff_eq_zero, zero_tsub]
          exact hmin.1.1 (by aesop)
        ┬и have := h_ind _ le_rfl
          simp_all only
          exact absurd (componentAvoiding_disjoint_T G T u)
            (Set.not_disjoint_iff.mpr РЪеx, this, hxTРЪЕ)
      exact h РЪеw.getVert (i - 1), by grind, h_adjРЪЕ
  exact hmin.2 T' (erase_ssubset hxT) hT'_sep

omit [Fintype V] [DecidableEq V] in
/-- `IsSeparator` is symmetric in `u` and `v`. -/
lemma isSeparator_comm (G : SimpleGraph V) (u v : V) (T : Finset V) :
    IsSeparator G u v T Рєћ IsSeparator G v u T := by
  constructor <;> rintro РЪеhРѓЂ, hРѓѓ, hРѓЃРЪЕ <;> refine РЪеby tauto, by tauto, ?_РЪЕ <;>
    intro w <;> have := hРѓЃ w.reverse <;> aesop

omit [Fintype V] [DecidableEq V] in
/-- `IsMinSeparator` is symmetric in `u` and `v`. -/
lemma isMinSeparator_comm (G : SimpleGraph V) (u v : V) (T : Finset V) :
    IsMinSeparator G u v T Рєћ IsMinSeparator G v u T := by
  grind [IsMinSeparator, isSeparator_comm]

/-- For a minimal `(u,v)`-separator `T`, we have
`T = outerNeighborhood G Sрхц` where `Sрхц` is the `u`-component avoiding `T`. -/
lemma T_eq_outerNeighborhood_component (G : SimpleGraph V) [DecidableRel G.Adj] (u v : V)
    (T : Finset V) (hT : IsMinSeparator G u v T) :
    T = outerNeighborhood G (Set.toFinite (componentAvoiding G T u)).toFinset := by
  ext x
  constructor
  ┬и intro hxT
    obtain РЪеy, hy_comp, hy_adjРЪЕ := minSep_T_sub_outerNbhd G T u v hT x hxT
    exact mem_filter.mpr РЪеmem_univ x,
      fun hx Рєд (componentAvoiding_disjoint_T G T u).le_bot РЪеby aesop, hxTРЪЕ,
      y, by aesop, hy_adjРЪЕ
  ┬и intro hx
    obtain РЪеy, hy, hadjРЪЕ := (mem_filter.mp hx).2.2
    exact outerNbhd_component_sub G T u x
      (fun hx_comp Рєд by have := (mem_filter.mp hx).2.1; aesop)
      РЪеy, by aesop, hadjРЪЕ

/-! ## Key structural lemma -/

/-- Every minimal `(u,v)`-separator is either small
(`card РЅц Рїі|V|/3РїІ`) or the outer neighbourhood of a small set.
This is the core of Brada─Ї's pigeonhole argument. -/
lemma minSep_mem_smallOrNeighborhood (G : SimpleGraph V) [DecidableRel G.Adj] (u v : V)
    (T : Finset V) (hT : IsMinSeparator G u v T) :
    T.card РЅц Fintype.card V / 3 Рѕе
    РѕЃ S : Finset V, S.card РЅц Fintype.card V / 3 РѕД T = outerNeighborhood G S := by
  by_cases h : T.card РЅц Fintype.card V / 3
  ┬и exact Or.inl h
  ┬и set Su := (Set.toFinite (componentAvoiding G T u)).toFinset
    set Sv := (Set.toFinite (componentAvoiding G T v)).toFinset
    have h_union : Su.card + Sv.card + T.card РЅц Fintype.card V := by
      rw [Рєљ card_union_of_disjoint,
          Рєљ card_union_of_disjoint]
      ┬и exact card_le_univ _
      ┬и simp +zetaDelta only [not_le, disjoint_union_left] at *
        exact РЪеdisjoint_left.mpr fun x hx hx' Рєд by
            have := componentAvoiding_disjoint_T G T u
            exact this.le_bot
              РЪеby simpa using hx, by simpa using hx'РЪЕ,
          disjoint_left.mpr fun x hx hx' Рєд by
            have := componentAvoiding_disjoint_T G T v
            exact this.le_bot
              РЪеby simpa using hx, by simpa using hx'РЪЕРЪЕ
      ┬и exact disjoint_left.mpr fun x hxu hxv Рєд
          Set.disjoint_left.mp
            (componentAvoiding_disjoint_uv G T u v hT.1)
            (Set.Finite.mem_toFinset _ |>.1 hxu)
            (Set.Finite.mem_toFinset _ |>.1 hxv)
    have : Su.card РЅц Fintype.card V / 3 Рѕе Sv.card РЅц Fintype.card V / 3 := by omega
    rcases this with hSu | hSv
    ┬и exact Or.inr РЪеSu, hSu,
        T_eq_outerNeighborhood_component G u v T hTРЪЕ
    ┬и exact Or.inr РЪеSv, hSv, by
        convert T_eq_outerNeighborhood_component G v u T
          (isMinSeparator_comm G u v T |>.1 hT) using 1РЪЕ

/-! ## Main bound -/

omit [DecidableEq V] in
/-- **Brada─Ї's Theorem (Erd┼Љs Problem 150).** The number of minimal `(u,v)`-separators in a graph
on `n` vertices is at most `2 ┬и РѕЉ_{k=0}^{Рїіn/3РїІ} C(n, k)`. -/
theorem numMinSeps_le (G : SimpleGraph V) (u v : V) :
    numMinSeps G u v РЅц
      2 * РѕЉ k Рѕѕ range (Fintype.card V / 3 + 1), (Fintype.card V).choose k := by
  classical
  suffices h :
      (minSepSet G u v).ncard РЅц
        (univ.filter fun S : Finset V Рєд S.card РЅц Fintype.card V / 3).card +
        (univ.filter fun S : Finset V Рєд S.card РЅц Fintype.card V / 3).card by
    convert h using 1
    rw [show (filter (fun S : Finset V Рєд S.card РЅц Fintype.card V / 3) univ) =
      Finset.biUnion (range (Fintype.card V / 3 + 1))
        fun k Рєд powersetCard k univ from ?_, card_biUnion]
    ┬и simp [two_mul, card_powersetCard]
    ┬и exact fun i hi j hj hij Рєд disjoint_left.mpr fun x hx hx' Рєд hij <| by
        rw [mem_powersetCard] at hx hx'; omega
    ┬и ext S; simp [mem_biUnion, mem_powersetCard]
  have h_sub :
      minSepSet G u v Ріє
        (РєЉ(univ.filter fun S : Finset V Рєд S.card РЅц Fintype.card V / 3) : Set (Finset V)) Рѕф
        (РєЉ(image (fun S : Finset V Рєд outerNeighborhood G S)
          (univ.filter fun S : Finset V Рєд S.card РЅц Fintype.card V / 3)) :
            Set (Finset V)) := by
    intro T hT
    have := minSep_mem_smallOrNeighborhood G u v T hT
    simp only [Set.mem_union, mem_coe, mem_filter, mem_univ, true_and, mem_image]
    rcases this with h | РЪеS, hS, hTSРЪЕ <;> grind
  calc (minSepSet G u v).ncard
      РЅц _ := Set.ncard_le_ncard h_sub
    _ РЅц _ := Set.ncard_union_le _ _
    _ РЅц _ := Nat.add_le_add
      (by rw [Set.ncard_coe_finset]) (by rw [Set.ncard_coe_finset]; exact card_image_le)

section BradacFull

/-! ## ┬Д1. Binary entropy and the precise bound ╬▒ РЅц 2^{H(1/3)}

The *binary entropy function* is
`HРѓѓ(p) = -p logРѓѓ p - (1-p) logРѓѓ(1-p)`. Brada─Ї's bound
`numMinSeps РЅц 2┬и╬Б_{kРЅцn/3} C(n,k)` combined with the standard
entropy bound on binomial tail sums gives
`c(n)^{1/n} Рєњ ╬▒ РЅц 2^{HРѓѓ(1/3)} РЅѕ 1.8899Рђд`.
-/

/-- The binary entropy function
`HРѓѓ(p) = -p logРѓѓ p - (1-p) logРѓѓ(1-p)`, using logarithm base 2.
Defined for all reals; meaningful on `[0,1]`. -/
noncomputable def binEntropyРѓѓ (p : РёЮ) : РёЮ :=
  -(p * Real.logb 2 p + (1 - p) * Real.logb 2 (1 - p))

/-! ### Binomial tail sum entropy bound

The standard bound: for `0 < ╬▒ < 1/2`,
`╬Б_{k=0}^{Рїі╬▒nРїІ} C(n,k) РЅц 2^{HРѓѓ(╬▒)┬иn}`.
-/

/-- The binomial tail sum satisfies the entropy bound: for any `╬х > 0`, eventually
`РѕЉ_{k=0}^{Рїіn/3РїІ} C(n,k) РЅц 2^{(HРѓѓ(1/3)+╬х)┬иn}`. -/
theorem binomial_tail_entropy_bound (╬х : РёЮ) (h╬х : 0 < ╬х) :
    РѕЃ N : РёЋ, Рѕђ n : РёЋ, N РЅц n Рєњ
      (РѕЉ k Рѕѕ range (n / 3 + 1), (n.choose k : РёЮ)) РЅц
        (2 : РёЮ) ^ ((binEntropyРѓѓ (1/3) + ╬х) * РєЉn) := by
  have h_entropy_bound : Рѕђ n : РёЋ,
      (РѕЉ k Рѕѕ range (n / 3 + 1), (n.choose k : РёЮ)) РЅц
        (n + 1) * 2 ^ ((binEntropyРѓѓ (1 / 3) : РёЮ) * n) := by
    have h_binom_sum : Рѕђ n : РёЋ,
        (РѕЉ k Рѕѕ range (n / 3 + 1), (n.choose k : РёЮ)) РЅц
          (n + 1) * (2 : РёЮ) ^ (n * (-(1 / 3 : РёЮ) * Real.logb 2 (1 / 3) -
            (2 / 3 : РёЮ) * Real.logb 2 (2 / 3))) := by
      intro n
      have h_binom_sum : Рѕђ k Рѕѕ range (n / 3 + 1),
          (n.choose k : РёЮ) РЅц
            (2 : РёЮ) ^ (n * (-(1 / 3 : РёЮ) * Real.logb 2 (1 / 3) -
              (2 / 3 : РёЮ) * Real.logb 2 (2 / 3))) := by
        intro k hk
        have h_binom : (n.choose k : РёЮ) РЅц
            (1 / 3) ^ (-k : РёЮ) * (2 / 3) ^ (-(n - k) : РёЮ) := by
          have h_binom :
              (n.choose k : РёЮ) * (1 / 3 : РёЮ) ^ k * (2 / 3 : РёЮ) ^ (n - k) РЅц 1 := by
            have h_binom :
                (n.choose k : РёЮ) * (1 / 3 : РёЮ) ^ k * (2 / 3 : РёЮ) ^ (n - k) РЅц
                (РѕЉ i Рѕѕ range (n + 1),
                  (n.choose i : РёЮ) * (1 / 3 : РёЮ) ^ i * (2 / 3 : РёЮ) ^ (n - i)) :=
              le_trans (by norm_num)
                (single_le_sum (fun i _ Рєд by positivity)
                  (mem_range.mpr (Nat.lt_succ_of_le (show k РЅц n from by
                    linarith [mem_range.mp hk, Nat.div_mul_le_self n 3]))))
            have h_binom_sum :
                РѕЉ i Рѕѕ range (n + 1),
                  (n.choose i : РёЮ) * (1 / 3 : РёЮ) ^ i * (2 / 3 : РёЮ) ^ (n - i) =
                  (1 / 3 + 2 / 3) ^ n := by
              rw [add_pow]; congr; ext; ring
            exact h_binom.trans <| h_binom_sum.symm РќИ by norm_num
          norm_num [Real.rpow_neg] at *
          rw [inv_mul_eq_div, le_div_iffРѓђ] <;> norm_num [Real.rpow_sub] at *
          rw [le_div_iffРѓђ (by positivity)]
          convert mul_le_mul_of_nonneg_right h_binom
            (pow_nonneg (by norm_num : (0 : РёЮ) РЅц 2 / 3) k) using 1
          ┬и ring_nf
            simp [mul_assoc, Рєљ pow_add,
              add_tsub_cancel_of_le (show k РЅц n from hk.trans (Nat.div_le_self _ _))]
          ┬и ring
        convert h_binom.trans _ using 1 ; (
          try (norm_num [Real.rpow_def_of_pos, Real.logb]; ring_nf; norm_num))
        rw [Рєљ Real.exp_add]
        norm_num [Real.log_div]; ring_nf; norm_num
        nlinarith [Real.log_pos one_lt_two, show (k : РёЮ) РЅц n / 3 by
            exact le_div_iffРѓђ' (by norm_num) |>.2 <| by
              norm_cast; linarith [mem_range.mp hk, Nat.div_mul_le_self n 3]]
      refine le_trans (sum_le_sum h_binom_sum) ?_
      norm_num; ring_nf; norm_cast
      norm_num [Nat.succ_le_iff]
      exact mul_le_mul_of_nonneg_right
        (mod_cast Nat.div_le_self _ _) (by positivity)
    convert h_binom_sum using 3
    norm_num [binEntropyРѓѓ]; ring_nf
  have h_exp_growth_bound : РѕЃ N : РёЋ, Рѕђ n РЅЦ N, (n + 1 : РёЮ) РЅц 2 ^ (╬х * n) := by
    have h_exp_growth : Filter.Tendsto
        (fun n : РёЋ Рєд (n + 1 : РёЮ) / 2 ^ (╬х * n)) Filter.atTop (nhds 0) := by
      suffices h_log : Filter.Tendsto
          (fun m : РёЮ Рєд (m / Real.log 2 + 1) / Real.exp (╬х * m))
          Filter.atTop (nhds 0) by
        convert h_log.comp (tendsto_natCast_atTop_atTop.atTop_mul_const
            (Real.log_pos one_lt_two)) using 2
        norm_num [Real.rpow_def_of_pos]; ring_nf
      have h_lim : Filter.Tendsto (fun m : РёЮ Рєд m / Real.exp (╬х * m))
          Filter.atTop (nhds 0) := by
        suffices h_lim_y : Filter.Tendsto (fun y : РёЮ Рєд y / Real.exp y)
            Filter.atTop (nhds 0) by
          have := h_lim_y.comp (Filter.tendsto_id.const_mul_atTop h╬х)
          convert this.const_mul ╬хРЂ╗┬╣ using 2 <;>
            norm_num [div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm, h╬х.ne']
        simpa [Real.exp_neg] using Real.tendsto_pow_mul_exp_neg_atTop_nhds_zero 1
      ring_nf
      simpa [div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm] using Filter.Tendsto.add
        (h_lim.mul_const (Real.log 2)РЂ╗┬╣)
        (tendsto_inv_atTop_zero.comp
          (Real.tendsto_exp_atTop.comp (Filter.tendsto_id.atTop_mul_const h╬х)))
    exact Filter.eventually_atTop.mp (h_exp_growth.eventually (gt_mem_nhds zero_lt_one)) |>
      fun РЪеN, hNРЪЕ Рєд РЪеN, fun n hn Рєд by
        have := hN n hn; rw [div_lt_one (by positivity)] at this; linarithРЪЕ
  obtain РЪеN, hNРЪЕ := h_exp_growth_bound; use N
  intro n hn
  convert le_trans (h_entropy_bound n)
    (mul_le_mul_of_nonneg_right (hN n hn)
      (by positivity)) using 1
  rw [Рєљ Real.rpow_add (by positivity)]; ring_nf

/-! ## ┬Д2. Global count `c(n)` and its bound

`c(n)` is the maximum number of minimal vertex cuts (i.e., minimal
vertex separators for *some* pair `u РЅа v`) over all simple graphs
on `n` vertices. The per-pair bound implies a global bound. -/

/-- A *minimal vertex cut* in `G` is a set that is a minimal
`(u,v)`-separator for some pair of distinct vertices `u, v`. -/
def IsMinCut (G : SimpleGraph V) (T : Finset V) : Prop :=
  РѕЃ u v : V, u РЅа v РѕД IsMinSeparator G u v T

/-- The set of all minimal vertex cuts in `G`. -/
def minCutSet (G : SimpleGraph V) : Set (Finset V) :=
  {T | IsMinCut G T}

/-- The number of minimal vertex cuts in `G`. -/
noncomputable def numMinCuts (G : SimpleGraph V) : РёЋ :=
  (minCutSet G).ncard

/-- `c(n)` is the maximum number of minimal vertex cuts over all simple graphs on `Fin n`. We use
`sSup` of a finite set of natural numbers. -/
noncomputable def c (n : РёЋ) : РёЋ :=
  sSup {k : РёЋ | РѕЃ (G : SimpleGraph (Fin n)) (_ : DecidableRel G.Adj), numMinCuts G = k}

omit [Fintype V] [DecidableEq V] in
/-- Every minimal cut is a minimal separator for some pair, so the set of all minimal cuts is the
union over pairs of `minSepSet`. -/
lemma minCutSet_subset_union (G : SimpleGraph V) :
    minCutSet G Ріє РІЃ (u : V) (v : V), minSepSet G u v := by
  intro T РЪеu, v, _, huvРЪЕ
  exact Set.mem_iUnion.mpr РЪеu, Set.mem_iUnion.mpr РЪеv, huvРЪЕРЪЕ

/-- The sharper global bound: every minimal vertex cut is a minimal
`(u,v)`-separator for some `u, v`, so is counted by the per-pair
bound. Since the per-pair bound counts sets of size `РЅц n/3` or
neighbourhoods of such sets, the global count is at most
`2 ┬и РѕЉ_{kРЅцn/3} C(n,k)`. -/
theorem c_n_bound (n : РёЋ) :
    c n РЅц 2 * РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k := by
  refine csSup_le ?_ ?_
  ┬и exact РЪе_, РЪеРіЦ, inferInstance, rflРЪЕРЪЕ
  ┬и have h_numMinCuts_le :
        Рѕђ (G : SimpleGraph (Fin n)) [DecidableRel G.Adj],
        numMinCuts G РЅц 2 * РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k := by
      intro G hG
      have h_numMinSeps_le : Рѕђ u v : Fin n, u РЅа v Рєњ
          numMinSeps G u v РЅц 2 * РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k := by
        intro u v huv
        apply Erdos150.numMinSeps_le G u v |> le_trans <| by norm_num [Fintype.card_fin]
      have h_numMinCuts_le :
          (minCutSet G).ncard РЅц 2 * РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k := by
        have : minCutSet G Ріє РІЃ (u : Fin n) (v : Fin n), minSepSet G u v :=
          minCutSet_subset_union G
        have h_minSepSet_subset : Рѕђ u v : Fin n, u РЅа v Рєњ
            minSepSet G u v Ріє
              filter (fun T Рєд T.card РЅц n / 3 Рѕе
                  РѕЃ S : Finset (Fin n), S.card РЅц n / 3 РѕД T = outerNeighborhood G S)
                (powerset (univ : Finset (Fin n))) := by
          intro u v huv T hT
          have hT_minSep : IsMinSeparator G u v T := hT
          have := minSep_mem_smallOrNeighborhood G u v T hT_minSep
          aesop
        have h_ncard_le :
            (minCutSet G).ncard РЅц
              (filter (fun T Рєд T.card РЅц n / 3 Рѕе
                  РѕЃ S : Finset (Fin n), S.card РЅц n / 3 РѕД T = outerNeighborhood G S)
                (powerset (univ : Finset (Fin n)))).card := by
          rw [Рєљ Set.ncard_coe_finset]
          exact Set.ncard_le_ncard
            (show minCutSet G Ріє _ from fun x hx Рєд by
              rcases hx with РЪеu, v, huv, hРЪЕ
              exact h_minSepSet_subset u v huv h)
        have h_small_card :
            (filter (fun T Рєд T.card РЅц n / 3)
              (powerset (univ : Finset (Fin n)))).card РЅц
              РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k := by
          rw [show filter (fun T Рєд card T РЅц n / 3)
              (powerset (univ : Finset (Fin n))) =
            Finset.biUnion (range (n / 3 + 1))
              fun k Рєд powersetCard k (univ : Finset (Fin n))
            from ?_, card_biUnion] <;>
            norm_num [card_powersetCard]
          ┬и exact fun i hi j hj hij Рєд disjoint_left.mpr fun x hxРѓЂ hxРѓѓ Рєд hij <| by
                  rw [mem_powersetCard] at hxРѓЂ hxРѓѓ; aesop
          ┬и ext; simp [mem_biUnion, mem_powersetCard]
        have h_nbhd_card :
            (filter (fun T Рєд
                РѕЃ S : Finset (Fin n), S.card РЅц n / 3 РѕД T = outerNeighborhood G S)
              (powerset (univ : Finset (Fin n)))).card РЅц
              РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k := by
          have h_img :
              (image (fun S : Finset (Fin n) Рєд outerNeighborhood G S)
                (filter (fun S Рєд S.card РЅц n / 3)
                  (powerset (univ : Finset (Fin n))))).card РЅц
                РѕЉ k Рѕѕ range (n / 3 + 1), n.choose k :=
            le_trans card_image_le h_small_card
          exact le_trans (card_le_card fun x hx Рєд by aesop) h_img
        calc (minCutSet G).ncard
            РЅц _ := h_ncard_le
          _ РЅц _ := card_le_card (fun x hx Рєд by aesop)
          _ РЅц _ := card_union_le _ _
          _ РЅц _ := add_le_add h_small_card h_nbhd_card
          _ = _ := by linarith
      exact h_numMinCuts_le
    aesop

end BradacFull

section LimitAndBound

open Filter Topology Real

/-! ## ┬Д4. The limit ╬▒ exists and ╬▒ РЅц 2^{H(1/3)} -/

/-- The maximum number of minimal `(u,v)`-separators over all simple graphs on `n` vertices and all
pairs `u РЅа v`. Returns `0` for `n < 2`. -/
noncomputable def maxPairSeps (n : РёЋ) : РёЋ :=
  sSup {k : РёЋ | РѕЃ (G : SimpleGraph (Fin n)) (_ : DecidableRel G.Adj) (u v : Fin n),
    u РЅа v РѕД numMinSeps G u v = k}

/-- The set defining `maxPairSeps` is nonempty for `n РЅЦ 2`. -/
lemma maxPairSeps_set_nonempty {n : РёЋ} (hn : 2 РЅц n) :
    {k : РёЋ | РѕЃ (G : SimpleGraph (Fin n)) (_ : DecidableRel G.Adj) (u v : Fin n),
      u РЅа v РѕД numMinSeps G u v = k}.Nonempty := by
  by_contra h_empty
  simp_all only [Set.Nonempty, ne_eq, exists_const, Set.mem_setOf_eq, РєЊexistsAndEq, not_exists]
  exact absurd (h_empty РЪе0, by linarithРЪЕ РЪе1, by linarithРЪЕ) (by norm_num)

/-- The set defining `maxPairSeps` is bounded above. -/
lemma maxPairSeps_bdd_above (n : РёЋ) :
    BddAbove {k : РёЋ | РѕЃ (G : SimpleGraph (Fin n)) (_ : DecidableRel G.Adj) (u v : Fin n),
      u РЅа v РѕД numMinSeps G u v = k} := by
  use 2 ^ n
  rintro k РЪеG, x, u, v, huv, rflРЪЕ
  refine le_trans (Set.ncard_le_ncard (show minSepSet G u v Ріє Set.univ from Set.subset_univ _)) ?_
  norm_num [Set.ncard_univ]

/-- `maxPairSeps n РЅЦ 1` for `n РЅЦ 2`. -/
lemma maxPairSeps_pos {n : РёЋ} (hn : 2 РЅц n) : 0 < maxPairSeps n := by
  have h_sep : IsMinSeparator (РіЦ : SimpleGraph (Fin n)) РЪе0, by linarithРЪЕ РЪе1, by linarithРЪЕ РѕЁ := by
    constructor <;> norm_num [IsSeparator]; rintro РЪеРЪЕ; aesop
  exact (Nat.pos_of_ne_zero (by
    rw [numMinSeps]; exact Set.ncard_ne_zero_of_mem h_sep)).trans_le <|
      le_csSup (maxPairSeps_bdd_above n) РЪе_, inferInstance, _, _, by norm_num, rflРЪЕ

/-- `maxPairSeps n РЅц 2^n`. -/
lemma maxPairSeps_le_two_pow (n : РёЋ) : maxPairSeps n РЅц 2 ^ n := by
  apply csSup_le'
  rintro k РЪеG, x, u, v, huv, rflРЪЕ
  calc numMinSeps G u v РЅц Set.univ.ncard := Set.ncard_le_ncard (Set.subset_univ _)
    _ = 2 ^ n := by norm_num [Set.ncard_univ]

/-- Every minimal separator for a specific pair is a minimal cut, so `maxPairSeps n РЅц c n`. -/
lemma maxPairSeps_le_c (n : РёЋ) : maxPairSeps n РЅц c n := by
  have h_subset :
      Рѕђ k Рѕѕ {k : РёЋ | РѕЃ (G : SimpleGraph (Fin n)) (_ : DecidableRel G.Adj) (u v : Fin n),
        u РЅа v РѕД numMinSeps G u v = k}, k РЅц c n := by
    intro k hk
    obtain РЪеG, x, u, v, huv, hk_eqРЪЕ := hk
    have h_card : numMinSeps G u v РЅц numMinCuts G := Set.ncard_le_ncard fun T hT Рєд РЪеu, v, huv, hTРЪЕ
    exact hk_eq РќИ le_trans h_card <| le_csSup
      (Set.Finite.bddAbove <| Set.Finite.subset
        (Set.toFinite <| Set.range fun G : SimpleGraph (Fin n) Рєд numMinCuts G)
          fun x hx Рєд by aesop) РЪеG, x, rflРЪЕ
  exact csSup_le' h_subset

/-- The number of minimal cuts is at most `n^2 * maxPairSeps n`. -/
lemma c_le_sq_mul_maxPairSeps (n : РёЋ) : c n РЅц n ^ 2 * maxPairSeps n := by
  have h_c_le : Рѕђ G : SimpleGraph (Fin n), numMinCuts G РЅц n ^ 2 * maxPairSeps n := by
    intro G
    have h_numMinCuts_le :
        numMinCuts G РЅц РѕЉ u : Fin n, РѕЉ v : Fin n,
          if u РЅа v then numMinSeps G u v else 0 := by
      have h_card_le :
          (minCutSet G).ncard РЅц РѕЉ u : Fin n, РѕЉ v : Fin n,
            (if u РЅа v then (minSepSet G u v).ncard else 0) := by
        have h_card_le : Рѕђ (S : Finset (Fin n ├Ќ Fin n)),
            (РІЃ p Рѕѕ S, if p.1 РЅа p.2 then minSepSet G p.1 p.2 else РѕЁ).ncard РЅц
              РѕЉ p Рѕѕ S,
                (if p.1 РЅа p.2 then (minSepSet G p.1 p.2).ncard else 0) := by
          intro S
          induction S using Finset.induction with
          | empty => norm_num [Set.ncard_empty]
          | insert _ _ h_nmem ih =>
            simp_all only [ne_eq, ite_not, mem_insert, Set.iUnion_iUnion_eq_or_left,
              sum_insert h_nmem]
            exact le_trans (Set.ncard_union_le _ _) (add_le_add (by aesop) ih)
        convert h_card_le (univ : Finset (Fin n ├Ќ Fin n)) using 1
        ┬и congr with x; aesop
        ┬и erw [sum_product]
      convert h_card_le using 1
    have h_numMinSeps_le_maxPairSeps : Рѕђ u v : Fin n, u РЅа v Рєњ
        numMinSeps G u v РЅц maxPairSeps n :=
      fun u v huv Рєд le_csSup (maxPairSeps_bdd_above n) <| by grind +splitIndPred
    refine le_trans h_numMinCuts_le ?_
    refine le_trans (sum_le_sum fun i hi Рєд
      sum_le_sum fun j hj Рєд
        show (if i РЅа j then numMinSeps G i j else 0) РЅц
          maxPairSeps n from by aesop) ?_
    norm_num; ring_nf; norm_num
  exact csSup_le' fun k hk Рєд by aesop

/-! ### Merged graph construction for super-multiplicativity -/

/-- Embedding of `GРѓЂ`'s vertex `i` into the merged graph. Maps `0..n` to `0..n` and `n+1` to
`n+m+1`. -/
def mergeEmbРѓЂ (n m : РёЋ) (i : Fin (n + 2)) : Fin (n + m + 2) :=
  if h : i.val РЅц n then РЪеi.val, by omegaРЪЕ
  else РЪеn + m + 1, by omegaРЪЕ

/-- Embedding of `GРѓѓ`'s vertex `j` into the merged graph. Maps `0` to `0`, `1..m` to `n+1..n+m`,
and `m+1` to `n+m+1`. -/
def mergeEmbРѓѓ (n m : РёЋ) (j : Fin (m + 2)) : Fin (n + m + 2) :=
  if j.val = 0 then РЪе0, by omegaРЪЕ
  else if h : j.val РЅц m then РЪеn + j.val, by omegaРЪЕ
  else РЪеn + m + 1, by omegaРЪЕ

/-- `mergeEmbРѓЂ` is injective. -/
lemma mergeEmbРѓЂ_injective (n m : РёЋ) : Function.Injective (mergeEmbРѓЂ n m) := by
  intro i j hij
  by_cases hi : i.val РЅц n
  ┬и by_cases hj : j.val РЅц n
    ┬и unfold mergeEmbРѓЂ at hij; aesop
    ┬и simp_all [Fin.ext_iff, mergeEmbРѓЂ]
  ┬и by_cases hj : j.val РЅц n <;>
      simp_all [Fin.ext_iff, mergeEmbРѓЂ]
    ┬и linarith
    ┬и grind

/-- `mergeEmbРѓѓ` is injective. -/
lemma mergeEmbРѓѓ_injective (n m : РёЋ) : Function.Injective (mergeEmbРѓѓ n m) := by
  unfold mergeEmbРѓѓ; intro i j h
  rcases i with РЪе_ | i, hiРЪЕ <;> rcases j with РЪе_ | j, hjРЪЕ <;> norm_num at h Ріб
  ┬и split_ifs at h <;> cases h
  ┬и split_ifs at h <;> cases h
  ┬и grind

/-- `mergeEmbРѓЂ` maps `0` to `0`. -/
lemma mergeEmbРѓЂ_source (n m : РёЋ) :
    mergeEmbРѓЂ n m РЪе0, by omegaРЪЕ = (РЪе0, by omegaРЪЕ : Fin (n + m + 2)) := by
  unfold mergeEmbРѓЂ; aesop

/-- `mergeEmbРѓЂ` maps `n+1` to `n+m+1`. -/
lemma mergeEmbРѓЂ_sink (n m : РёЋ) :
    mergeEmbРѓЂ n m РЪеn + 1, by omegaРЪЕ = (РЪеn + m + 1, by omegaРЪЕ : Fin (n + m + 2)) := by
  unfold mergeEmbРѓЂ; aesop

/-- `mergeEmbРѓѓ` maps `0` to `0`. -/
lemma mergeEmbРѓѓ_source (n m : РёЋ) :
    mergeEmbРѓѓ n m РЪе0, by omegaРЪЕ = (РЪе0, by omegaРЪЕ : Fin (n + m + 2)) := by
  unfold mergeEmbРѓѓ; simp

/-- `mergeEmbРѓѓ` maps `m+1` to `n+m+1`. -/
lemma mergeEmbРѓѓ_sink (n m : РёЋ) :
    mergeEmbРѓѓ n m РЪеm + 1, by omegaРЪЕ = (РЪеn + m + 1, by omegaРЪЕ : Fin (n + m + 2)) :=
  Eq.symm (by unfold mergeEmbРѓѓ; simp)

/-- Adjacency relation for the merged graph. -/
def mergedAdj (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2))) (GРѓѓ : SimpleGraph (Fin (m + 2)))
    (a b : Fin (n + m + 2)) : Prop :=
  (РѕЃ i j : Fin (n + 2), mergeEmbРѓЂ n m i = a РѕД mergeEmbРѓЂ n m j = b РѕД GРѓЂ.Adj i j) Рѕе
  (РѕЃ i j : Fin (m + 2), mergeEmbРѓѓ n m i = a РѕД mergeEmbРѓѓ n m j = b РѕД GРѓѓ.Adj i j)

/-- The merged adjacency relation is symmetric. -/
lemma mergedAdj_symm (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) : Symmetric (mergedAdj n m GРѓЂ GРѓѓ) := by
  intro a b hab
  rcases hab with
    (РЪеi, j, rfl, rfl, hijРЪЕ | РЪеi, j, rfl, rfl, hijРЪЕ) <;>
    [exact Or.inl РЪеj, i, rfl, rfl, GРѓЂ.symm hijРЪЕ;
     exact Or.inr РЪеj, i, rfl, rfl, GРѓѓ.symm hijРЪЕ]

/-- The merged adjacency relation is irreflexive. -/
lemma mergedAdj_loopless (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) : Std.Irrefl (mergedAdj n m GРѓЂ GРѓѓ) := by
  constructor; intro a ha; obtain РЪеi, j, hi, hj, hijРЪЕ := ha
  ┬и have := mergeEmbРѓЂ_injective n m (hi.trans hj.symm); aesop
  ┬и obtain РЪеi, j, hi, hj, hijРЪЕ := Рђ╣_Рђ║
    have := mergeEmbРѓѓ_injective n m (hi.trans hj.symm); aesop

/-- The merged graph on `Fin (n+m+2)`, formed by identifying the endpoints of `GРѓЂ` on `Fin (n+2)`
and `GРѓѓ` on `Fin (m+2)`. -/
def mergedGraph (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) : SimpleGraph (Fin (n + m + 2)) where
  Adj := mergedAdj n m GРѓЂ GРѓѓ
  symm := mergedAdj_symm n m GРѓЂ GРѓѓ
  loopless := mergedAdj_loopless n m GРѓЂ GРѓѓ

/-- The image of `mergeEmbРѓЂ`'s internal vertices (`{1,...,n}`) is disjoint from `mergeEmbРѓѓ`'s
internal vertices (`{n+1,...,n+m}`). -/
lemma emb_images_internal_disjoint (n m : РёЋ)
    (SРѓЂ : Finset (Fin (n + 2)))
    (SРѓѓ : Finset (Fin (m + 2)))
    (hSРѓЂ : Рѕђ x Рѕѕ SРѓЂ, x.val РЅа 0 РѕД x.val РЅа n + 1)
    (hSРѓѓ : Рѕђ x Рѕѕ SРѓѓ, x.val РЅа 0 РѕД x.val РЅа m + 1) :
    Disjoint (SРѓЂ.image (mergeEmbРѓЂ n m))
      (SРѓѓ.image (mergeEmbРѓѓ n m)) := by
  simp only [Finset.disjoint_left, mem_image, not_exists]
  intro a ha x hx
  grind [mergeEmbРѓЂ, mergeEmbРѓѓ]

/-- The images of `mergeEmbРѓЂ` and `mergeEmbРѓѓ` overlap only at the shared endpoints `0` and
`n+m+1`. -/
lemma mergeEmb_image_inter (n m : РёЋ) (i : Fin (n + 2)) (j : Fin (m + 2))
    (h : mergeEmbРѓЂ n m i = mergeEmbРѓѓ n m j) :
    (i = РЪе0, by omegaРЪЕ РѕД j = РЪе0, by omegaРЪЕ) Рѕе (i = РЪеn + 1, by omegaРЪЕ РѕД j = РЪеm + 1, by omegaРЪЕ) := by
  grind +locals

/-- If `u` is in the combined component and `v` is an adjacent vertex not in `T`, then `v` is also
in the combined component. -/
lemma merged_component_closure (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ : Finset (Fin (n + 2))) (SРѓѓ : Finset (Fin (m + 2)))
    (hРѓЂ : IsSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ)
    (hРѓѓ : IsSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ) (u v : Fin (n + m + 2))
    (hu : u Рѕѕ Set.image (mergeEmbРѓЂ n m) (componentAvoiding GРѓЂ SРѓЂ РЪе0, by omegaРЪЕ) Рѕф
      Set.image (mergeEmbРѓѓ n m) (componentAvoiding GРѓѓ SРѓѓ РЪе0, by omegaРЪЕ))
    (hv : v РѕЅ SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m))
    (hadj : (mergedGraph n m GРѓЂ GРѓѓ).Adj u v) :
    v Рѕѕ Set.image (mergeEmbРѓЂ n m) (componentAvoiding GРѓЂ SРѓЂ РЪе0, by omegaРЪЕ) Рѕф
      Set.image (mergeEmbРѓѓ n m) (componentAvoiding GРѓѓ SРѓѓ РЪе0, by omegaРЪЕ) := by
  rcases hadj with hРѓЂ | hРѓѓ
  ┬и rcases hРѓЂ with РЪеi, j, rfl, rfl, hijРЪЕ
    simp_all only [IsSeparator, Fin.zero_eta, Set.mem_union, Set.mem_image, mem_union, mem_image,
      not_or, not_exists, not_and]
    rcases hu with (РЪеx, hx, hx'РЪЕ | РЪеx, hx, hx'РЪЕ)
    ┬и refine Or.inl РЪеj, ?_, rflРЪЕ
      exact componentAvoiding_adj_closed GРѓЂ SРѓЂ 0 i j
        (by rwa [mergeEmbРѓЂ_injective n m hx'] at hx) (fun hj Рєд hv.1 j hj rfl) hij
    ┬и have h_cases : x = РЪе0, by omegaРЪЕ РѕД i = РЪе0, by omegaРЪЕ Рѕе
          x = РЪеm + 1, by omegaРЪЕ РѕД i = РЪеn + 1, by omegaРЪЕ := by grind +locals
      cases h_cases
      ┬и grind +suggestions
      ┬и simp_all only [mergeEmbРѓЂ, mergeEmbРѓѓ]
        exact False.elim <| hРѓѓ.2.1 <| by
          obtain РЪеw, hwРЪЕ := hx
          exact False.elim <| hРѓѓ.2.2 w |> fun РЪеx, hxРѓЂ, hxРѓѓРЪЕ Рєд hw x hxРѓЂ hxРѓѓ
  ┬и obtain РЪеi, j, rfl, rfl, hijРЪЕ := hРѓѓ
    simp_all only [Fin.zero_eta]
    rcases hu with hu | hu <;>
      simp_all only [Set.mem_union, Set.mem_image, (mergeEmbРѓѓ_injective n m).eq_iff, exists_eq_right]
    ┬и obtain РЪеx, hx, hx'РЪЕ := hu
      have := mergeEmb_image_inter n m x i
      simp_all only [mem_union, mem_image, not_or, not_exists, not_and, Fin.zero_eta, forall_const]
      cases this <;> simp_all only [IsSeparator]
      ┬и exact Or.inr РЪеSimpleGraph.Walk.cons hij SimpleGraph.Walk.nil, by aesopРЪЕ
      ┬и contrapose! hРѓЂ; aesop
    ┬и exact Or.inr (componentAvoiding_adj_closed GРѓѓ SРѓѓ 0 i j hu (by aesop) hij)

/-- Vertices reachable from `0` in the merged graph avoiding `T = embРѓЂ(SРѓЂ) Рѕф embРѓѓ(SРѓѓ)` are
contained in `embРѓЂ(CРѓЂ) Рѕф embРѓѓ(CРѓѓ)`. -/
lemma merged_walk_stays_in_components (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ : Finset (Fin (n + 2))) (SРѓѓ : Finset (Fin (m + 2)))
    (hРѓЂ : IsSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ)
    (hРѓѓ : IsSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ) (u v : Fin (n + m + 2))
    (hu : u Рѕѕ Set.image (mergeEmbРѓЂ n m) (componentAvoiding GРѓЂ SРѓЂ РЪе0, by omegaРЪЕ) Рѕф
      Set.image (mergeEmbРѓѓ n m) (componentAvoiding GРѓѓ SРѓѓ РЪе0, by omegaРЪЕ))
    (w : (mergedGraph n m GРѓЂ GРѓѓ).Walk u v)
    (hw : Рѕђ x Рѕѕ w.support,
      x РѕЅ SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m)) :
    v Рѕѕ Set.image (mergeEmbРѓЂ n m) (componentAvoiding GРѓЂ SРѓЂ РЪе0, by omegaРЪЕ) Рѕф
      Set.image (mergeEmbРѓѓ n m) (componentAvoiding GРѓѓ SРѓѓ РЪе0, by omegaРЪЕ) := by
  revert v
  intro v w hw
  induction w with
  | nil => simp_all
  | cons hadj _ ih =>
    apply ih
    ┬и apply merged_component_closure n m GРѓЂ GРѓѓ SРѓЂ SРѓѓ Рђ╣_Рђ║ Рђ╣_Рђ║ _ _ hu (by exact hw _ (by simp)) hadj
    ┬и exact fun x hx Рєд hw x <| by simp [hx]

/-- The combined set `embРѓЂ(SРѓЂ) Рѕф embРѓѓ(SРѓѓ)` is a separator in the merged graph when
`SРѓЂ` and `SРѓѓ` are separators in `GРѓЂ` and `GРѓѓ`. -/
lemma merged_isSeparator (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ : Finset (Fin (n + 2))) (SРѓѓ : Finset (Fin (m + 2)))
    (hРѓЂ : IsSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ)
    (hРѓѓ : IsSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ) :
    IsSeparator (mergedGraph n m GРѓЂ GРѓѓ) РЪе0, by omegaРЪЕ РЪеn + m + 1, by omegaРЪЕ
      (SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m)) := by
  refine РЪе?_, ?_, ?_РЪЕ
  ┬и simp_all only [IsSeparator, Fin.zero_eta, mem_union, mem_image, not_or, not_exists, not_and]
    unfold mergeEmbРѓЂ mergeEmbРѓѓ; aesop
  ┬и simp_all only [IsSeparator, Fin.zero_eta, mem_union, mem_image, not_or, not_exists,
      mergeEmbРѓЂ, mergeEmbРѓѓ]
    grind +suggestions
  ┬и intro w
    by_contra h_contra
    push_neg at h_contra
    have h_sink_in_components :
        РЪеn + m + 1, by omegaРЪЕ Рѕѕ
          Set.image (mergeEmbРѓЂ n m) (componentAvoiding GРѓЂ SРѓЂ РЪе0, by omegaРЪЕ) Рѕф
          Set.image (mergeEmbРѓѓ n m) (componentAvoiding GРѓѓ SРѓѓ РЪе0, by omegaРЪЕ) := by
      apply merged_walk_stays_in_components n m GРѓЂ GРѓѓ SРѓЂ SРѓѓ hРѓЂ hРѓѓ РЪе0, by omegaРЪЕ
        РЪеn + m + 1, by omegaРЪЕ (Or.inl РЪеРЪе0, by omegaРЪЕ,
          mem_componentAvoiding_self _ _ _ (by simpa using hРѓЂ.1), mergeEmbРѓЂ_source n mРЪЕ) w h_contra
    rcases h_sink_in_components with h | h
    ┬и obtain РЪеx, hx, hx'РЪЕ := h
      simp_all [mergeEmbРѓЂ]
      by_cases hx'' : x.val РЅц n <;> simp_all [Fin.ext_iff]
      have hx_eq : x = РЪеn + 1, by omegaРЪЕ := Fin.ext (by linarith [Fin.is_lt x])
      have := hРѓЂ.2.2
      simp_all [IsSeparator]
      obtain РЪеw, hwРЪЕ := hx; specialize this w; aesop
    ┬и obtain РЪеx, hx, hx'РЪЕ := h
      unfold mergeEmbРѓѓ at hx'
      rcases x with РЪе_ | x, hxРЪЕ <;> norm_num at *
      simp_all only [Fin.zero_eta, Fin.ext_iff]
      rcases lt_or_eq_of_le (Nat.le_of_lt_succ Рђ╣_Рђ║) with h | h <;> first | omega | skip
      have : x = m := by omega
      subst this
      exact absurd hx (fun h Рєд hРѓѓ.2.1 <| by
        obtain РЪеw, hwРЪЕ := h; exact False.elim <| hРѓѓ.2.2 w |> fun РЪеx, hxРѓЂ, hxРѓѓРЪЕ Рєд hw x hxРѓЂ hxРѓѓ)

/-- Stronger version of `walk_map_embРѓЂ`: tracks that the support of the lifted walk corresponds
exactly to `mergeEmbРѓЂ` applied to the original walk's support. -/
lemma walk_map_embРѓЂ_support (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (u v : Fin (n + 2)) (w : GРѓЂ.Walk u v) :
    РѕЃ w' : (mergedGraph n m GРѓЂ GРѓѓ).Walk (mergeEmbРѓЂ n m u) (mergeEmbРѓЂ n m v),
      Рѕђ x Рѕѕ w'.support, РѕЃ y Рѕѕ w.support, x = mergeEmbРѓЂ n m y := by
  induction w with
  | nil => exact РЪе.nil, by simp [SimpleGraph.Walk.support]РЪЕ
  | cons hadj _ ih =>
    obtain РЪеw', hw'РЪЕ := ih
    exact РЪе.cons (Or.inl РЪе_, _, rfl, rfl, hadjРЪЕ) w', by simp_all [SimpleGraph.Walk.support_cons]РЪЕ

/-- Stronger version of `walk_map_embРѓѓ`: tracks that the support of the lifted walk corresponds
exactly to `mergeEmbРѓѓ` applied to the original walk's support. -/
lemma walk_map_embРѓѓ_support (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (u v : Fin (m + 2)) (w : GРѓѓ.Walk u v) :
    РѕЃ w' : (mergedGraph n m GРѓЂ GРѓѓ).Walk (mergeEmbРѓѓ n m u) (mergeEmbРѓѓ n m v),
      Рѕђ x Рѕѕ w'.support, РѕЃ y Рѕѕ w.support, x = mergeEmbРѓѓ n m y := by
  induction w
  ┬и exact РЪеSimpleGraph.Walk.nil, by simpРЪЕ
  ┬и rename_i hРѓЂ hРѓѓ hРѓЃ
    obtain РЪеw', hw'РЪЕ := hРѓЃ
    use SimpleGraph.Walk.cons
      (show (mergedGraph n m GРѓЂ GРѓѓ).Adj (mergeEmbРѓѓ n m _) (mergeEmbРѓѓ n m _) from ?_) w'
    ┬и simp_all
    ┬и exact Or.inr РЪе_, _, rfl, rfl, hРѓЂРЪЕ

/-- If a walk in `GРѓЂ` avoids `SРѓЂ \ {a}`, its image in the merged graph avoids any `T'` that is a
proper subset of `embРѓЂ(SРѓЂ) Рѕф embРѓѓ(SРѓѓ)` missing `embРѓЂ(a)`. -/
lemma merged_walk_avoids_subРѓЂ (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ : Finset (Fin (n + 2))) (SРѓѓ : Finset (Fin (m + 2)))
    (hРѓѓ : IsSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ)
    (a : Fin (n + 2)) (ha : a Рѕѕ SРѓЂ) (T' : Finset (Fin (n + m + 2)))
    (hT' : T' Ріє SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m))
    (ha_out : mergeEmbРѓЂ n m a РѕЅ T')
    (wРѓЂ : GРѓЂ.Walk РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ)
    (hwРѓЂ : Рѕђ y Рѕѕ wРѓЂ.support, y РѕЅ SРѓЂ.erase a) :
    РѕЃ w' : (mergedGraph n m GРѓЂ GРѓѓ).Walk РЪе0, by omegaРЪЕ РЪеn + m + 1, by omegaРЪЕ,
      Рѕђ x Рѕѕ w'.support, x РѕЅ T' := by
  obtain РЪеw', hw'РЪЕ :
      РѕЃ w' : (mergedGraph n m GРѓЂ GРѓѓ).Walk
          (mergeEmbРѓЂ n m РЪе0, by omegaРЪЕ) (mergeEmbРѓЂ n m РЪеn + 1, by omegaРЪЕ),
        Рѕђ x Рѕѕ w'.support, РѕЃ y Рѕѕ wРѓЂ.support, x = mergeEmbРѓЂ n m y :=
    walk_map_embРѓЂ_support n m GРѓЂ GРѓѓ
      РЪе0, Decidable.byContradiction fun a Рєд mergeEmbРѓЂ_source._proof_1 n aРЪЕ
      РЪеn + 1, Decidable.byContradiction fun a Рєд mergeEmbРѓЂ_sink._proof_1 n aРЪЕ wРѓЂ
  use w'.copy (by exact mergeEmbРѓЂ_source n m) (by exact mergeEmbРѓЂ_sink n m)
  intro x hx hx'
  specialize hw' x
  simp_all only [Fin.zero_eta, subset_iff, mem_union, mem_image, Walk.support_copy, forall_const]
  obtain РЪеy, hy, rflРЪЕ := hw'
  specialize hT' hx'
  rcases hT' with (РЪеz, hz, hz'РЪЕ | РЪеz, hz, hz'РЪЕ)
  ┬и have := mergeEmbРѓЂ_injective n m hz'; aesop
  ┬и have := mergeEmb_image_inter n m y z
    simp_all only [mem_erase, ne_eq, not_and, Fin.zero_eta, forall_const]
    cases this <;> simp_all [IsSeparator]

/-- Same as `merged_walk_avoids_subРѓЂ` but for `GРѓѓ`. -/
lemma merged_walk_avoids_subРѓѓ (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ : Finset (Fin (n + 2))) (SРѓѓ : Finset (Fin (m + 2)))
    (hРѓЂ : IsSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ) (b : Fin (m + 2))
    (T' : Finset (Fin (n + m + 2)))
    (hT' : T' Ріє SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m))
    (hb_out : mergeEmbРѓѓ n m b РѕЅ T')
    (wРѓѓ : GРѓѓ.Walk РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ)
    (hwРѓѓ : Рѕђ y Рѕѕ wРѓѓ.support, y РѕЅ SРѓѓ.erase b) :
    РѕЃ w' : (mergedGraph n m GРѓЂ GРѓѓ).Walk РЪе0, by omegaРЪЕ РЪеn + m + 1, by omegaРЪЕ,
      Рѕђ x Рѕѕ w'.support, x РѕЅ T' := by
  obtain РЪеw', hw'РЪЕ :=
    walk_map_embРѓѓ_support n m GРѓЂ GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ wРѓѓ
  refine РЪеw'.copy (mergeEmbРѓѓ_source n m) (mergeEmbРѓѓ_sink n m), ?_РЪЕ
  simp_all only [Fin.zero_eta, subset_iff, mem_union, mem_image, mem_erase, ne_eq, not_and,
    Walk.support_copy]
  intro x hx hxT'
  obtain РЪеy, hy, rflРЪЕ := hw' x hx
  by_cases hyb : y = b <;>
    simp_all [IsSeparator]
  obtain РЪеa, ha, ha'РЪЕ := hT' hxT'
  ┬и have := mergeEmb_image_inter n m a y ha'
    simp_all; grind +ring
  ┬и obtain РЪеa, ha, ha'РЪЕ := Рђ╣_Рђ║
    have := mergeEmbРѓѓ_injective n m ha'; aesop

/-- The combined set is a minimal separator. -/
lemma merged_isMinSeparator (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ : Finset (Fin (n + 2))) (SРѓѓ : Finset (Fin (m + 2)))
    (hРѓЂ : IsMinSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ)
    (hРѓѓ : IsMinSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ) :
    IsMinSeparator (mergedGraph n m GРѓЂ GРѓѓ) РЪе0, by omegaРЪЕ РЪеn + m + 1, by omegaРЪЕ
      (SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m)) := by
  refine РЪе?_, ?_РЪЕ
  ┬и apply merged_isSeparator n m GРѓЂ GРѓѓ SРѓЂ SРѓѓ hРѓЂ.1 hРѓѓ.1
  ┬и intro T' hT' hT'_sub
    by_cases h_case :
        РѕЃ a Рѕѕ SРѓЂ.image (mergeEmbРѓЂ n m), a РѕЅ T'
    ┬и obtain РЪеa, haРѓЂ, haРѓѓРЪЕ := h_case
      obtain РЪеa', ha'_mem, rflРЪЕ := mem_image.mp haРѓЂ
      have ha'_walk :
          РѕЃ wРѓЂ : GРѓЂ.Walk РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ,
            Рѕђ y Рѕѕ wРѓЂ.support, y РѕЅ SРѓЂ.erase a' := by
        have := hРѓЂ.2 (SРѓЂ.erase a') ?_
        ┬и simp_all only [Fin.zero_eta, IsSeparator, mem_image, mem_erase, not_and, not_forall,
            not_exists]
          exact this
            (fun h Рєд by have := hРѓЂ.1.1; aesop)
            (fun h Рєд by have := hРѓЂ.1.2.1; aesop) |>
            fun РЪеwРѓЂ, hwРѓЂРЪЕ Рєд РЪеwРѓЂ, hwРѓЂРЪЕ
        ┬и simp_all only [Fin.zero_eta, IsSeparator, mem_image];exact erase_ssubset ha'_mem
      obtain РЪеwРѓЂ, hwРѓЂРЪЕ := ha'_walk
      obtain РЪеw', hw'РЪЕ :=
        merged_walk_avoids_subРѓЂ n m GРѓЂ GРѓѓ SРѓЂ SРѓѓ hРѓѓ.1 a' ha'_mem T' hT'.1 haРѓѓ wРѓЂ hwРѓЂ
      exact absurd hT'_sub (by unfold IsSeparator; aesop)
    ┬и obtain РЪеb, hbРЪЕ : РѕЃ b Рѕѕ SРѓѓ.image (mergeEmbРѓѓ n m), b РѕЅ T' := by grind
      obtain РЪеb', hb', hb'_not_in_T'РЪЕ :
          РѕЃ b' Рѕѕ SРѓѓ, mergeEmbРѓѓ n m b' = b РѕД mergeEmbРѓѓ n m b' РѕЅ T' := by grind
      obtain РЪеwРѓѓ, hwРѓѓРЪЕ :
          РѕЃ wРѓѓ : GРѓѓ.Walk РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ,
            Рѕђ y Рѕѕ wРѓѓ.support, y РѕЅ SРѓѓ.erase b' := by
        have := hРѓѓ.2 (SРѓѓ.erase b') ?_ <;>
          simp_all only [Fin.zero_eta, IsSeparator, mem_image, exists_exists_and_eq_and, not_exists,
            not_and, Decidable.not_not, mem_erase, ne_eq, not_forall]
        ┬и exact this
            (fun h Рєд by have := hРѓѓ.1.1; aesop)
            (fun h Рєд by have := hРѓѓ.1.2.1; aesop) |>
            fun РЪеwРѓѓ, hwРѓѓРЪЕ Рєд РЪеwРѓѓ, hwРѓѓРЪЕ
        ┬и exact erase_ssubset hb'
      obtain РЪеw', hw'РЪЕ : РѕЃ w' : (mergedGraph n m GРѓЂ GРѓѓ).Walk РЪе0, by omegaРЪЕ РЪеn + m + 1, by omegaРЪЕ,
        Рѕђ x Рѕѕ w'.support, x РѕЅ T' :=
          merged_walk_avoids_subРѓѓ n m GРѓЂ GРѓѓ SРѓЂ SРѓѓ hРѓЂ.1 b' T' hT'.subset hb'_not_in_T'.2 wРѓѓ hwРѓѓ
      exact absurd (hT'_sub.2.2 w') (by tauto)

/-- The map `(SРѓЂ, SРѓѓ) Рєд SРѓЂ.image mergeEmbРѓЂ Рѕф SРѓѓ.image mergeEmbРѓѓ` is injective on
pairs of min separators. -/
lemma merge_sep_injective (n m : РёЋ) (GРѓЂ : SimpleGraph (Fin (n + 2)))
    (GРѓѓ : SimpleGraph (Fin (m + 2))) (SРѓЂ SРѓЂ' : Finset (Fin (n + 2)))
    (SРѓѓ SРѓѓ' : Finset (Fin (m + 2)))
    (hSРѓЂ : IsMinSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ)
    (hSРѓЂ' : IsMinSeparator GРѓЂ РЪе0, by omegaРЪЕ РЪеn + 1, by omegaРЪЕ SРѓЂ')
    (hSРѓѓ : IsMinSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ)
    (hSРѓѓ' : IsMinSeparator GРѓѓ РЪе0, by omegaРЪЕ РЪеm + 1, by omegaРЪЕ SРѓѓ')
    (heq : SРѓЂ.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ.image (mergeEmbРѓѓ n m) =
      SРѓЂ'.image (mergeEmbРѓЂ n m) Рѕф SРѓѓ'.image (mergeEmbРѓѓ n m)) :
    SРѓЂ = SРѓЂ' РѕД SРѓѓ = SРѓѓ' := by
  have h_SРѓЂ_internal :
      Рѕђ x Рѕѕ SРѓЂ, x.val РЅа 0 РѕД x.val РЅа n + 1 := by
    intro x hx; refine РЪеfun h Рєд hSРѓЂ.1.1 ?_,
      fun h Рєд hSРѓЂ.1.2.1 ?_РЪЕ <;>
      rwa [show x = РЪе_, _РЪЕ from Fin.ext h] at hx
  have h_SРѓѓ_internal :
      Рѕђ y Рѕѕ SРѓѓ, y.val РЅа 0 РѕД y.val РЅа m + 1 := by
    intro y hy; refine РЪеfun h Рєд hSРѓѓ.1.1 ?_,
      fun h Рєд hSРѓѓ.1.2.1 ?_РЪЕ <;>
      rwa [show y = РЪе_, _РЪЕ from Fin.ext h] at hy
  have h_SРѓЂ'_internal :
      Рѕђ x Рѕѕ SРѓЂ', x.val РЅа 0 РѕД x.val РЅа n + 1 := by
    intro x hx; refine РЪеfun h Рєд hSРѓЂ'.1.1 ?_,
      fun h Рєд hSРѓЂ'.1.2.1 ?_РЪЕ <;>
      rwa [show x = РЪе_, _РЪЕ from Fin.ext h] at hx
  have h_SРѓѓ'_internal :
      Рѕђ y Рѕѕ SРѓѓ', y.val РЅа 0 РѕД y.val РЅа m + 1 := by
    intro y hy; refine РЪеfun h Рєд hSРѓѓ'.1.1 ?_,
      fun h Рєд hSРѓѓ'.1.2.1 ?_РЪЕ <;>
      rwa [show y = РЪе_, _РЪЕ from Fin.ext h] at hy
  have h_disj :
      Disjoint (SРѓЂ.image (mergeEmbРѓЂ n m)) (SРѓѓ'.image (mergeEmbРѓѓ n m)) РѕД
      Disjoint (SРѓЂ'.image (mergeEmbРѓЂ n m)) (SРѓѓ.image (mergeEmbРѓѓ n m)) :=
    РЪеemb_images_internal_disjoint n m SРѓЂ SРѓѓ' h_SРѓЂ_internal h_SРѓѓ'_internal,
      emb_images_internal_disjoint n m SРѓЂ' SРѓѓ h_SРѓЂ'_internal h_SРѓѓ_internalРЪЕ
  have h_eq :
      SРѓЂ.image (mergeEmbРѓЂ n m) = SРѓЂ'.image (mergeEmbРѓЂ n m) РѕД
      SРѓѓ.image (mergeEmbРѓѓ n m) = SРѓѓ'.image (mergeEmbРѓѓ n m) := by
    simp_all only [Fin.zero_eta, Finset.ext_iff, mem_union, mem_image, ne_eq, Fin.val_eq_zero_iff]
    constructor <;> intro a <;> specialize heq a <;>
      simp_all [Finset.disjoint_left]
    ┬и grind
    ┬и grind +extAll
  exact РЪеimage_injective (mergeEmbРѓЂ_injective n m) h_eq.1,
